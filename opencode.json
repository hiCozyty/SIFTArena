{
    "$schema": "https://opencode.ai/config.json",
    "provider": {
        "nvidiaOpenAI": {
            "npm": "@ai-sdk/openai-compatible",
            "name": "nvidiaOpenAI",
            "options": {
                "baseURL": "https://integrate.api.nvidia.com/v1"
            },
            "models": {
                "qwen/qwen3.5-397b-a17b": {
                    "name": "qwen/qwen3.5-397b-a17b",
                    "options": {
                        "temperature": 0.6,
                        "topP": 0.95,
                        "topK": 20,
                        "chat_template_kwargs": { "enable_thinking": true }
                    }
                }
            }
        }
    }
}