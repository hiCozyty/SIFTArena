{
    "$schema": "https://opencode.ai/config.json",

    "agent": {
        "build": {
            "model": "opencode-go/deepseek-v4-flash",
            "temperature": 0.6
        },
        "plan": {
            "model": "opencode-go/deepseek-v4-flash",
            "temperature": 0.3
        }
    },
    "mcp": {
        "Ludus API": {
            "type": "local",
            "command": ["bunx","-y", "apidog-mcp-server@latest", "--site-id=761007"],
            "enabled": true
        },
        "context7": {
            "type": "remote",
            "url": "https://mcp.context7.com/mcp",
            "enabled": true
        }
    }
}